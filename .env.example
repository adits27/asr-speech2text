# MockStar Speech Processing Configuration

# Whisper Model Configuration
# Options: tiny, base, small, medium, large
# Recommendation: 'base' for development, 'small' or 'medium' for production
WHISPER_MODEL_SIZE=base

# Server Configuration
HOST=0.0.0.0
PORT=8000

# File Upload Configuration
MAX_FILE_SIZE=26214400  # 25MB in bytes
UPLOAD_DIR=uploads

# CORS Configuration (comma-separated origins)
# For development: http://localhost:3000,http://localhost:5173
# For production: https://mockstar.com
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=INFO

# Optional: API Keys (if using cloud services)
# OPENAI_API_KEY=your_openai_api_key_here
# ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Optional: Database (for session persistence)
# DATABASE_URL=postgresql://user:password@localhost/mockstar

# Optional: Redis (for caching/task queue)
# REDIS_URL=redis://localhost:6379/0

# Optional: Sentry (error tracking)
# SENTRY_DSN=your_sentry_dsn_here

# Production Settings
# WORKERS=4
# THREADS=2
# TIMEOUT=120
